# =============================================================
# ZOOMMA NEXTJS TEMPLATE — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores reais
# =============================================================

# ------ Supabase (Banco de dados + Auth) ------
# Crie um novo projeto em: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------ IA: Anthropic Claude ------
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ------ IA: OpenAI (opcional, caso use GPT) ------
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ------ Apify (Scraping) ------
# Obtenha em: https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_...

# ------ Google Cloud / Vertex AI ------
# Crie uma service account em: https://console.cloud.google.com/iam-admin/serviceaccounts
# Cole o conteúdo do JSON como string (em uma só linha)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ------ Resend (Envio de Emails) ------
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@seudominio.com.br
RESEND_TO_EMAIL=voce@seudominio.com.br

# ------ Telegram Bot (Notificações) ------
# Crie um bot em: https://t.me/BotFather
# Obtenha o chat_id enviando uma mensagem ao bot e acessando:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=0000000000:AAH...
TELEGRAM_CHAT_ID=0000000000
